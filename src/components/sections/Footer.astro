---
interface Props {
  lang?: 'fr' | 'en';
  page?: 'home' | 'geo';
}

const { lang = 'fr', page = 'home' } = Astro.props;

const geoPath = lang === 'en' ? '/en/geo-agency' : '/agence-geo';
const homePath = lang === 'en' ? '/en' : '/';
const partnersPath = lang === 'en' ? '/en/partners' : '/partners';

// On the home page, the third nav link goes to Agence GEO.
// On the GEO page, the third nav link goes to Agence Reddit (home).
const crossLink = page === 'geo' ? homePath : geoPath;
const crossLabel = page === 'geo'
  ? (lang === 'en' ? 'Reddit Agency' : 'Agence Reddit')
  : (lang === 'en' ? 'GEO Agency' : 'Agence GEO');

const labels = {
  method: lang === 'en' ? 'Our method' : 'Notre méthode',
  pricing: lang === 'en' ? 'Pricing' : 'Tarifs',
  faq: 'FAQ',
  partners: lang === 'en' ? 'Partners' : 'Partenaires',
  rights: lang === 'en' ? 'All rights reserved.' : 'Tous droits réservés.',
};

import logoAsset from '@/assets/logo_reddit_agence.webp';
const logo = typeof logoAsset === 'string' ? logoAsset : logoAsset.src;
---

<footer class="py-12 px-6 border-t border-border/50">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col gap-10">
      <div class="flex flex-col md:flex-row justify-between gap-8">
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-2">
            <img src={logo} alt="UpvotePartners" class="h-7 w-7 rounded-lg" loading="lazy" />
            <span class="text-foreground font-semibold text-lg">UpvotePartners</span>
          </div>
          <div class="flex items-center gap-3">
            <a href="https://x.com/mateodr_" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="X">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </a>
            <a href="https://www.linkedin.com/in/mateodrouillard/" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
          </div>
          <a href="mailto:contact@upvotepartners.com" class="flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            contact@upvotepartners.com
          </a>
        </div>

        <nav class="flex gap-16">
          <div class="flex flex-col gap-3">
            <a href="#how-it-works" class="text-sm text-muted-foreground hover:text-foreground transition-colors text-left">
              {labels.method}
            </a>
            <a href="#pricing" class="text-sm text-muted-foreground hover:text-foreground transition-colors text-left">
              {labels.pricing}
            </a>
            <a href={crossLink} class="text-sm text-muted-foreground hover:text-foreground transition-colors text-left">
              {crossLabel}
            </a>
          </div>
          <div class="flex flex-col gap-3">
            <a href="#faq" class="text-sm text-muted-foreground hover:text-foreground transition-colors text-left">
              {labels.faq}
            </a>
            <a href={partnersPath} class="text-sm text-muted-foreground hover:text-foreground transition-colors text-left">
              {labels.partners}
            </a>
          </div>
        </nav>
      </div>

      <div class="h-px bg-border/50"></div>
      <p class="text-xs text-muted-foreground">
        Copyright &copy;UpvotePartners. {labels.rights}
      </p>
    </div>
  </div>
</footer>
