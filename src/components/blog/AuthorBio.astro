---
import type { Author } from '@/data/authors';

interface Props {
  author: Author;
}

const { author } = Astro.props;
---

<aside class="not-prose my-12 rounded-2xl border border-border/60 bg-card p-6 sm:p-8">
  <div class="flex flex-col sm:flex-row gap-5 sm:items-center">
    <img
      src={author.avatar}
      alt={author.name}
      width={72}
      height={72}
      loading="lazy"
      class="w-18 h-18 sm:w-20 sm:h-20 rounded-2xl object-cover border border-border/60 flex-shrink-0"
    />
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-primary mb-1">Écrit par</p>
      <p class="text-lg font-bold text-foreground">{author.name}</p>
      <p class="text-sm text-muted-foreground mb-3">{author.role}</p>
      <p class="text-sm text-muted-foreground leading-relaxed">{author.bio}</p>
      <div class="flex items-center gap-3 mt-4">
        {author.sameAs.map((url) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-primary transition-colors"
            aria-label={url.includes('linkedin') ? 'LinkedIn' : 'X (Twitter)'}
          >
            {url.includes('linkedin') ? (
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            ) : (
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</aside>
