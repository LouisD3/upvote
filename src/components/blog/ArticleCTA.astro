---
// CTA contextuel de fin d'article → page commerciale (maillage interne, ancre riche en mot-clé)
// + audit gratuit (Calendly). La cible dépend du `hub` de l'article.
interface Props {
  hub?: 'home' | 'agence-geo';
}

const { hub = 'home' } = Astro.props;
const CALENDLY_URL = 'https://calendly.com/mateo-drouillard-upvotepartners/audit';

const target =
  hub === 'agence-geo'
    ? {
        href: '/agence-geo',
        heading: 'Envie d’être cité par ChatGPT et Perplexity ?',
        anchor: 'agence GEO',
        lead:
          'Notre agence GEO utilise Reddit pour faire apparaître votre marque dans les réponses des moteurs d’IA.',
      }
    : {
        href: '/',
        heading: 'Envie de transformer Reddit en canal d’acquisition ?',
        anchor: 'agence marketing Reddit',
        lead:
          'UpvotePartners gère de A à Z votre présence Reddit pour générer des leads qualifiés et renforcer votre SEO.',
      };
---

<aside class="not-prose my-12 rounded-2xl border border-primary/20 bg-primary/5 p-8 text-center">
  <h2 class="text-2xl font-bold text-foreground mb-3">{target.heading}</h2>
  <p class="text-muted-foreground max-w-xl mx-auto mb-6 leading-relaxed">
    {target.lead} Découvrez notre <a href={target.href} class="text-primary font-semibold hover:underline">{target.anchor}</a>.
  </p>
  <a
    href={CALENDLY_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center justify-center gap-2 h-11 px-6 rounded-md bg-primary text-primary-foreground font-semibold shadow-lg shadow-primary/20 hover:scale-105 transition-transform duration-300"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"/></svg>
    Réserver un audit gratuit
  </a>
</aside>
