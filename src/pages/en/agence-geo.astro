---
import Layout from '@/layouts/Layout.astro';
import '@/index.css';
import { Header } from '@/components/landing/Header';
import CTAButton from '@/components/islands/CTAButton';
import FAQAccordion from '@/components/islands/FAQAccordion';
import Footer from '@/components/sections/Footer.astro';
import LogoBanner from '@/components/sections/LogoBanner.astro';
import logoAsset from '@/assets/logo_reddit_agence.webp';
const logo = typeof logoAsset === 'string' ? logoAsset : logoAsset.src;
import mateoAvatarAsset from '@/assets/mateo-avatar.webp';
const mateoAvatar = typeof mateoAvatarAsset === 'string' ? mateoAvatarAsset : mateoAvatarAsset.src;
import claudeLogoAsset from '@/assets/claude-logo.webp';
const claudeLogo = typeof claudeLogoAsset === 'string' ? claudeLogoAsset : claudeLogoAsset.src;
import perplexityLogoAsset from '@/assets/perplexity-logo.webp';
const perplexityLogo = typeof perplexityLogoAsset === 'string' ? perplexityLogoAsset : perplexityLogoAsset.src;

const PROMPT = "Why can Reddit be a powerful acquisition channel for my startup?";
const encodedPrompt = encodeURIComponent(PROMPT);

const faqGeo = [
  {
    q: "What is GEO (Generative Engine Optimization)?",
    a: "GEO is the practice of optimizing your brand's visibility in AI-generated responses (ChatGPT, Perplexity, Claude and Google AI Overviews). Unlike traditional SEO which targets Google rankings, GEO ensures your brand gets cited when users ask an AI for recommendations in your category. It's the next evolution of online visibility.",
  },
  {
    q: "Why is Reddit the best lever for GEO?",
    a: "Reddit is the #1 source that AI engines cite. Reddit threads are human-verified discussions, ranked by the community — not marketing content. LLMs like ChatGPT and Perplexity cite Reddit disproportionately. Plus, Google ranks Reddit threads at the top of SERPs since 2024, and AI models use the Google index as a primary source. A strong Reddit presence = visibility on Google AND in AI responses.",
  },
  {
    q: "How long before seeing AI citations?",
    a: "Most clients start seeing their brand mentioned in AI responses within 2-3 months. First posts go live within 21 days. Reddit content compounds over time: a thread published today can generate citations for months as AI models continuously re-index popular Reddit discussions. We require a minimum 3-month commitment because GEO is a channel that compounds.",
  },
  {
    q: "How do you measure GEO performance?",
    a: "We measure: the number of AI citations your brand receives on ChatGPT, Perplexity, Claude and Google AI Overviews; your share of voice in AI responses vs competitors; Reddit post performance (upvotes, comments, traffic); SEO positions of your Reddit threads; and qualified leads generated through organic AI discovery. Each month, you receive a detailed GEO performance report.",
  },
  {
    q: "What's the difference between GEO and SEO?",
    a: "SEO optimizes for Google rankings (blue links). GEO optimizes for AI-generated responses (ChatGPT, Perplexity, etc.). Our Reddit strategy boosts both simultaneously. Reddit threads rank on Google (SEO) AND get cited by AI engines (GEO). You get double visibility from a single channel. SEO alone is no longer enough as more and more users are shifting to AI search.",
  },
  {
    q: "Is this strategy safe? Can accounts get banned?",
    a: "Our approach is 100% organic and compliant with Reddit guidelines. We don't spam, don't use bots, and don't make promotional posts. We create genuinely valuable content that naturally mentions your brand in context. Our accounts are warmed up for weeks, build real karma, and authentically participate in communities. In 3+ years of operation, we've never had a client brand negatively impacted.",
  },
  {
    q: "Why choose a GEO agency over traditional SEO?",
    a: "Traditional SEO is still relevant, but it no longer covers the entire buying journey. In 2026, a growing share of B2B buyers start their research in ChatGPT or Perplexity, not Google. If you're only visible in blue links, you're missing out on this new channel. A GEO agency like UpvotePartners positions you on both fronts simultaneously: Google visibility (through Reddit threads that rank) AND citations in AI responses.",
  },
  {
    q: "Does GEO work for all industries?",
    a: "GEO is particularly effective for B2B SaaS companies, tech tools, professional services, and any category where buyers do comparative research before purchasing. If prospects are likely to ask an AI 'what is the best [your category]?', then GEO is relevant for you. We offer a free audit to evaluate your brand's GEO potential before any commitment.",
  },
  {
    q: "How much does a GEO agency cost?",
    a: "Our GEO agency plans start at 3,000 euros per month for the Foundation plan (5 Reddit posts per month + 25 targeted comments). The most popular plan is GEO Engine at 5,000 euros per month. Minimum commitment is 3 months because GEO is a channel that compounds over time. Compared to paid ads, the cost per lead with organic GEO is 3 to 8 times lower in the medium term.",
  },
];
---

<Layout
  title="GEO Agency: Appear in AI Answers | UpvotePartners"
  description="Get your brand mentioned in ChatGPT, Perplexity and Claude responses through Reddit. Free GEO audit."
  canonical="https://upvotepartners.com/en/agence-geo"
  lang="en"
  alternateUrl="https://upvotepartners.com/agence-geo"
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://upvotepartners.com/en"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "GEO Agency",
          "item": "https://upvotepartners.com/en/agence-geo"
        }
      ]
    }
    </script>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqGeo.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    })} />
  </Fragment>

  <div class="min-h-screen bg-background">
    <Header
      client:load
      lang="en"
      currentPath="/en/agence-geo"
      showLangToggle={true}
      homePath="/en"
      ctaLabel="Book free Audit"
      navItems={[
        { label: "How it works", sectionId: "how-it-works" },
        { label: "Pricing", sectionId: "pricing" },
        { label: "FAQ", sectionId: "faq" }
      ]}
    />
    <div class="pt-16">

      <!-- ═══════════════════════════ HERO GEO ═══════════════════════════ -->
      <section class="min-h-[90vh] flex flex-col items-center justify-start px-6 pt-16 pb-0 text-center relative overflow-hidden bg-gradient-hero">
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
          <div class="absolute top-[10%] left-[10%] w-[500px] h-[500px] rounded-full bg-primary/5 blur-[100px] animate-pulse"></div>
          <div class="absolute bottom-[20%] right-[10%] w-[400px] h-[400px] rounded-full bg-primary/3 blur-[80px] animate-pulse" style="animation-delay: 1s;"></div>
        </div>

        <div class="animate-fade-up relative z-10 mb-6" style="animation-delay: 50ms; animation-fill-mode: both;">
          <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-card/80 backdrop-blur-sm border border-border/50">
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 text-primary">
              <path d="M0 24V0h24v24H0zM6.951 5.896l4.112 7.708v5.064h1.583v-4.972l4.148-7.799h-1.749l-2.457 4.875c-.372.745-.688 1.434-.688 1.434s-.297-.708-.651-1.434L8.831 5.896h-1.88z" />
            </svg>
            <span class="text-sm font-medium text-muted-foreground">
              Trusted by YC startups
            </span>
          </div>
        </div>

        <div class="animate-fade-up max-w-3xl mx-auto relative z-10" style="animation-fill-mode: both;">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-tight">
            <span class="text-foreground">GEO Agency: </span>
            <span class="text-gradient">Get your brand mentioned</span>
            <span class="text-foreground"> in AI answers</span>
          </h1>
        </div>

        <div class="animate-fade-up mt-6 max-w-2xl mx-auto relative z-10" style="animation-delay: 200ms; animation-fill-mode: both;">
          <p class="text-lg md:text-xl text-muted-foreground leading-relaxed">
            We are a <strong class="text-foreground">GEO agency</strong> (Generative Engine Optimization) that uses Reddit as the primary lever to get your startup cited in AI responses. More visibility in LLMs = more qualified leads, on autopilot.
          </p>
        </div>

        <div class="animate-fade-up mt-8 relative z-10" style="animation-delay: 500ms; animation-fill-mode: both;">
          <CTAButton client:visible label="Book free GEO Audit" className="animate-wiggle-glow" />
          <p class="mt-4 text-sm text-muted-foreground font-medium animate-pulse">
            Limited spots — 3 slots remaining this month
          </p>
        </div>

        <LogoBanner title="Join the Startups using Reddit as an acquisition channel" />
      </section>

      <!-- ═══════════════════════════ GEO DEFINITION ═══════════════════════════ -->
      <section class="py-20 px-6 bg-gradient-section relative overflow-hidden">
        <div class="max-w-5xl mx-auto relative z-10">
          <div class="animate-fade-up" style="animation-fill-mode: both;">
            <div class="text-center mb-4">
              <span class="inline-block px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium mb-4">
                What is GEO?
              </span>
            </div>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground text-center mb-8 leading-tight max-w-3xl mx-auto">
              Generative Engine Optimization: <span class="text-gradient">the new SEO</span>
            </h2>
          </div>

          <div class="animate-fade-up" style="animation-delay: 100ms; animation-fill-mode: both;">
            <div class="max-w-3xl mx-auto mb-16 space-y-6">
              <p class="text-lg text-muted-foreground text-center leading-relaxed">
                A <strong class="text-foreground">GEO agency</strong> (Generative Engine Optimization) is a provider specialized in optimizing a brand's visibility within responses generated by AI engines: ChatGPT, Perplexity, Claude, Google AI Overviews and Bing Copilot. Unlike SEO which targets Google's 10 blue links, GEO targets the conversational responses that AIs deliver directly to users.
              </p>
              <p class="text-lg text-muted-foreground text-center leading-relaxed">
                In practice, when a prospect asks ChatGPT "what is the best tool for [your category]?", a <strong class="text-foreground">GEO agency</strong> ensures your brand appears in the response. It's a fundamental shift: from "being found when someone searches" to "being recommended when someone asks."
              </p>
              <p class="text-lg text-muted-foreground text-center leading-relaxed">
                According to a Gartner study (2026), <strong class="text-foreground">62% of B2B buyers</strong> now use an AI assistant to evaluate solutions before any sales contact. Companies absent from these responses are losing a growing share of their market, often without even realizing it.
              </p>
            </div>
          </div>

          <div class="grid md:grid-cols-3 gap-6">
            <!-- Stat 1: 62% -->
            <div class="animate-fade-up" style="animation-delay: 200ms; animation-fill-mode: both;">
              <div class="p-6 rounded-2xl bg-card/80 border border-border/50 hover:border-primary/30 transition-all duration-300 text-center h-full">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-primary"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>
                </div>
                <div class="text-3xl font-bold text-primary mb-2">62%</div>
                <div class="text-sm font-semibold text-foreground mb-1">of B2B buyers</div>
                <p class="text-sm text-muted-foreground">use AI to research solutions before purchasing (Gartner, 2026)</p>
              </div>
            </div>
            <!-- Stat 2: Reddit -->
            <div class="animate-fade-up" style="animation-delay: 300ms; animation-fill-mode: both;">
              <div class="p-6 rounded-2xl bg-card/80 border border-border/50 hover:border-primary/30 transition-all duration-300 text-center h-full">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-primary"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
                </div>
                <div class="text-3xl font-bold text-primary mb-2">Reddit</div>
                <div class="text-sm font-semibold text-foreground mb-1">AI's #1 source</div>
                <p class="text-sm text-muted-foreground">LLMs cite Reddit disproportionately because it's human-verified content</p>
              </div>
            </div>
            <!-- Stat 3: 3x -->
            <div class="animate-fade-up" style="animation-delay: 400ms; animation-fill-mode: both;">
              <div class="p-6 rounded-2xl bg-card/80 border border-border/50 hover:border-primary/30 transition-all duration-300 text-center h-full">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-primary"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                </div>
                <div class="text-3xl font-bold text-primary mb-2">3x</div>
                <div class="text-sm font-semibold text-foreground mb-1">more organic leads</div>
                <p class="text-sm text-muted-foreground">vs paid channels, AI visibility compounds over time with no marginal cost</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════ GEO vs SEO ═══════════════════════════ -->
      <section class="py-24 px-6 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-background via-card/20 to-background pointer-events-none"></div>
        <div class="max-w-5xl mx-auto relative z-10">
          <div class="animate-fade-up text-center mb-6" style="animation-fill-mode: both;">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 text-primary text-sm font-medium mb-6 border border-primary/20">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="M7 16h8"/><path d="M7 11h12"/><path d="M7 6h3"/></svg>
              Comparison
            </span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-8 max-w-3xl mx-auto">
              GEO vs SEO: <span class="text-gradient">what's the difference?</span>
            </h2>
            <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
              SEO and GEO don't oppose each other — they complement each other. Our GEO agency approach leverages Reddit to boost both simultaneously. Here's what sets them apart:
            </p>
          </div>

          <div class="animate-fade-up" style="animation-delay: 200ms; animation-fill-mode: both;">
            <div class="overflow-x-auto mt-12">
              <table class="w-full border-collapse">
                <thead>
                  <tr>
                    <th class="text-left p-4 text-sm font-semibold text-muted-foreground border-b border-border/50 w-1/5"></th>
                    <th class="text-left p-4 text-sm font-bold text-foreground border-b border-border/50 w-2/5">
                      <span class="inline-flex items-center gap-2">Traditional SEO</span>
                    </th>
                    <th class="text-left p-4 text-sm font-bold text-primary border-b border-primary/30 w-2/5 bg-primary/5 rounded-t-xl">
                      <span class="inline-flex items-center gap-2">GEO (our approach)</span>
                    </th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="border-b border-border/30">
                    <td class="p-4 text-sm font-semibold text-foreground">Goal</td>
                    <td class="p-4 text-sm text-muted-foreground">Rank in Google's 10 blue links</td>
                    <td class="p-4 text-sm text-foreground font-medium bg-primary/5">Get cited in AI conversational responses</td>
                  </tr>
                  <tr class="border-b border-border/30">
                    <td class="p-4 text-sm font-semibold text-foreground">Target engines</td>
                    <td class="p-4 text-sm text-muted-foreground">Google, Bing (traditional search)</td>
                    <td class="p-4 text-sm text-foreground font-medium bg-primary/5">ChatGPT, Perplexity, Claude, Google AI Overviews, Bing Copilot</td>
                  </tr>
                  <tr class="border-b border-border/30">
                    <td class="p-4 text-sm font-semibold text-foreground">Result format</td>
                    <td class="p-4 text-sm text-muted-foreground">Clickable link to your site</td>
                    <td class="p-4 text-sm text-foreground font-medium bg-primary/5">Direct mention of your brand in a text response</td>
                  </tr>
                  <tr class="border-b border-border/30">
                    <td class="p-4 text-sm font-semibold text-foreground">Main signal</td>
                    <td class="p-4 text-sm text-muted-foreground">Backlinks, on-page content, technical</td>
                    <td class="p-4 text-sm text-foreground font-medium bg-primary/5">Mentions in high-trust sources (Reddit, forums, expert articles)</td>
                  </tr>
                  <tr class="border-b border-border/30">
                    <td class="p-4 text-sm font-semibold text-foreground">Time to results</td>
                    <td class="p-4 text-sm text-muted-foreground">3-12 months depending on competition</td>
                    <td class="p-4 text-sm text-foreground font-medium bg-primary/5">2-3 months for first AI citations</td>
                  </tr>
                  <tr class="border-b border-border/30">
                    <td class="p-4 text-sm font-semibold text-foreground">Compounding effect</td>
                    <td class="p-4 text-sm text-muted-foreground">Rankings fluctuate with Google updates</td>
                    <td class="p-4 text-sm text-foreground font-medium bg-primary/5">AI citations persist and accumulate over time</td>
                  </tr>
                  <tr class="border-b-0">
                    <td class="p-4 text-sm font-semibold text-foreground">Success metric</td>
                    <td class="p-4 text-sm text-muted-foreground">SERP position, organic traffic</td>
                    <td class="p-4 text-sm text-foreground font-medium bg-primary/5">Number of AI citations, AI share of voice, leads via AI discovery</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="animate-fade-up" style="animation-delay: 400ms; animation-fill-mode: both;">
            <div class="mt-12 p-6 rounded-2xl bg-card border border-border/50">
              <p class="text-muted-foreground leading-relaxed">
                <strong class="text-foreground">Why does our Reddit strategy cover both?</strong> When we publish a Reddit thread mentioning your brand, it ranks on Google (SEO benefit) AND gets indexed by LLMs that cite it in their responses (GEO benefit). This dual mechanism is what makes Reddit the most effective channel for a <strong class="text-foreground">GEO agency</strong> in 2026. One investment, two visibility channels that compound over time.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════ PROBLEM GEO ═══════════════════════════ -->
      <section class="py-24 px-6 bg-gradient-section relative overflow-hidden">
        <div class="max-w-5xl mx-auto relative z-10">
          <div class="animate-fade-up" style="animation-fill-mode: both;">
            <div class="text-center mb-4">
              <span class="inline-block px-3 py-1 rounded-full bg-destructive/10 text-destructive text-sm font-medium mb-4">
                The problem
              </span>
            </div>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground text-center mb-8 leading-tight max-w-3xl mx-auto">
              Your competitors are cited by AI. <span class="text-gradient">Not you.</span>
            </h2>
          </div>

          <div class="animate-fade-up" style="animation-delay: 100ms; animation-fill-mode: both;">
            <p class="text-lg md:text-xl text-muted-foreground text-center mb-16 max-w-2xl mx-auto leading-relaxed">
              Every day, thousands of B2B buyers ask ChatGPT and Perplexity for recommendations. If your brand isn't in those responses, you're invisible to a growing share of your market.
            </p>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            <!-- Without GEO strategy -->
            <div class="animate-fade-up" style="animation-delay: 150ms; animation-fill-mode: both;">
              <div class="group h-full">
                <div class="h-full bg-card shadow-card rounded-2xl p-8 border border-destructive/20 transition-all duration-500 hover:shadow-lg hover:border-destructive/40">
                  <div class="flex items-center gap-4 mb-8">
                    <div class="w-12 h-12 rounded-xl bg-destructive/10 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-destructive"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                    </div>
                    <div>
                      <h3 class="text-xl font-bold text-foreground">Without a GEO strategy</h3>
                      <p class="text-sm text-muted-foreground">What happens to most startups</p>
                    </div>
                  </div>
                  <ul class="space-y-5">
                    <li class="flex items-start gap-4">
                      <div class="w-6 h-6 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-destructive"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      </div>
                      <span class="text-muted-foreground">Invisible in AI-generated responses</span>
                    </li>
                    <li class="flex items-start gap-4">
                      <div class="w-6 h-6 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-destructive"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      </div>
                      <span class="text-muted-foreground">Competitors capture AI-sourced leads</span>
                    </li>
                    <li class="flex items-start gap-4">
                      <div class="w-6 h-6 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-destructive"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      </div>
                      <span class="text-muted-foreground">No control over AI recommendations</span>
                    </li>
                    <li class="flex items-start gap-4">
                      <div class="w-6 h-6 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
