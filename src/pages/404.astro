---
import Layout from '@/layouts/Layout.astro';
import '@/index.css';
---

<Layout
  title="Page non trouvée — UpvotePartners"
  description="La page que vous recherchez n'existe pas."
>
  <div class="min-h-screen flex items-center justify-center bg-background">
    <div class="text-center">
      <h1 class="text-6xl font-bold text-foreground mb-4">404</h1>
      <p class="text-xl text-muted-foreground mb-8">Page non trouvée</p>
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-primary-foreground font-semibold hover:opacity-90 transition-opacity">
        Retour à l'accueil
      </a>
    </div>
  </div>
</Layout>
