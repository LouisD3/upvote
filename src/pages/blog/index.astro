---
import Layout from '@/layouts/Layout.astro';
import '@/index.css';
import { Header } from '@/components/landing/Header';
import Footer from '@/components/sections/Footer.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '@/lib/reading-time';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const SITE = 'https://upvotepartners.com';

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Blog UpvotePartners',
  description:
    "Guides et analyses sur le marketing Reddit et le GEO (Generative Engine Optimization) pour les startups.",
  url: `${SITE}/blog`,
  inLanguage: 'fr-FR',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE}/blog` },
  ],
};
---

<Layout
  title="Blog : Marketing Reddit & GEO | UpvotePartners"
  description="Guides, stratégies et analyses sur le marketing Reddit et le GEO pour startups : SEO indirect, citations IA, acquisition organique. Par UpvotePartners."
  canonical="https://upvotepartners.com/blog"
  lang="fr"
  ogImage="https://upvotepartners.com/og-blog.jpg"
  ogImageWidth="1200"
  ogImageHeight="630"
  orgSchema={false}
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionSchema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="min-h-screen bg-background">
    <Header
      client:load
      lang="fr"
      currentPath="/blog"
      showLangToggle={false}
      homePath="/"
      ctaLabel="Réserver un audit gratuit"
    />

    <div class="pt-16">
      <header class="max-w-5xl mx-auto px-6 pt-16 pb-10 text-center">
        <span class="inline-block px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium mb-4">
          Le blog
        </span>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-tight text-foreground mb-4">
          Marketing Reddit & GEO
        </h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto leading-relaxed">
          Stratégies, guides et analyses pour transformer Reddit en canal d'acquisition et faire citer votre marque
          par les moteurs d'IA.
        </p>
      </header>

      <section class="max-w-5xl mx-auto px-6 pb-24">
        {posts.length > 0 ? (
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {posts.map((post) => (
              <BlogCard
                href={`/blog/${post.id}`}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                readingTime={readingTime(post.body ?? '')}
              />
            ))}
          </div>
        ) : (
          <p class="text-center text-muted-foreground py-16">Les premiers articles arrivent bientôt.</p>
        )}
      </section>

      <Footer lang="fr" />
    </div>
  </div>
</Layout>
