---
import { getCollection, render } from 'astro:content';
import BlogPost from '@/layouts/BlogPost.astro';
import { getAuthor } from '@/data/authors';
import { readingTime } from '@/lib/reading-time';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, posts },
  }));
}

const { entry, posts } = Astro.props;
const { Content } = await render(entry);

const author = getAuthor(entry.data.author);
const rt = readingTime(entry.body ?? '');
const ogImage = entry.data.ogImage ?? '/og-blog.jpg';

// Articles liés : même cluster, hors article courant, max 2.
const related = entry.data.cluster
  ? posts
      .filter((p) => p.id !== entry.id && p.data.cluster === entry.data.cluster)
      .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
      .slice(0, 2)
      .map((p) => ({
        href: `/blog/${p.id}`,
        title: p.data.title,
        description: p.data.description,
        pubDate: p.data.pubDate,
        tags: p.data.tags,
        readingTime: readingTime(p.body ?? ''),
      }))
  : [];
---

<BlogPost
  title={entry.data.title}
  description={entry.data.description}
  slug={entry.id}
  pubDate={entry.data.pubDate}
  updatedDate={entry.data.updatedDate}
  author={author}
  ogImage={ogImage}
  readingTime={rt}
  faq={entry.data.faq}
  hub={entry.data.hub}
  tags={entry.data.tags}
  related={related}
>
  <Content />
</BlogPost>
