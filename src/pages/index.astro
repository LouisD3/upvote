---
import Layout from '@/layouts/Layout.astro';
import IndexPage from '@/react-pages/Index.tsx';
import '@/index.css';
import { faqReddit } from '@/data/faq-reddit';
---

<Layout
  title="Agence Reddit : Générez des leads qualifiés | UpvotePartners"
  description="UpvotePartners est l'agence Reddit n°1 pour les startups. Stratégie organique, leads qualifiés, visibilité SEO et citations IA via Reddit. Audit gratuit."
  canonical="https://upvotepartners.com"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqReddit.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    })} />
  </Fragment>

  <IndexPage client:idle />
</Layout>
