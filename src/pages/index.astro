---
import Layout from '@/layouts/Layout.astro';
import '@/index.css';
import { faqReddit } from '@/data/faq-reddit';
import { Header } from '@/components/landing/Header';
import CTAButton from '@/components/islands/CTAButton';
import FAQAccordion from '@/components/islands/FAQAccordion';
import Footer from '@/components/sections/Footer.astro';
import LogoBanner from '@/components/sections/LogoBanner.astro';
---

<Layout
  title="Agence Reddit : Générez des leads qualifiés | UpvotePartners"
  description="UpvotePartners est l'agence Reddit n°1 pour les startups. Stratégie organique, leads qualifiés, visibilité SEO et citations IA via Reddit. Audit gratuit."
  canonical="https://upvotepartners.com"
  lang="fr"
  alternateUrl="https://upvotepartners.com/en"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqReddit.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": a }
      }))
    })} />
  </Fragment>

  <div class="min-h-screen bg-background">
    <Header
      client:load
      lang="fr"
      currentPath="/"
      showLangToggle={true}
      homePath="/"
      ctaLabel="Réserver un audit gratuit"
      navItems={[
        { label: "Notre méthode", sectionId: "how-it-works" },
        { label: "Tarifs", sectionId: "pricing" },
        { label: "FAQ", sectionId: "faq" }
      ]}
    />

    <div class="pt-16">

      <!-- ============================================================
           HERO
           ============================================================ -->
      <section class="min-h-[90vh] flex flex-col items-center justify-start px-6 pt-16 pb-0 text-center relative overflow-hidden bg-gradient-hero">
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
          <div class="absolute top-[10%] left-[10%] w-[500px] h-[500px] rounded-full bg-primary/5 blur-[100px] animate-pulse"></div>
          <div class="absolute bottom-[20%] right-[10%] w-[400px] h-[400px] rounded-full bg-primary/3 blur-[80px] animate-pulse" style="animation-delay: 1s;"></div>
        </div>

        <div class="animate-fade-up relative z-10 mb-6" style="animation-delay: 50ms; animation-fill-mode: both;">
          <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-card/80 backdrop-blur-sm border border-border/50">
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 text-primary">
              <path d="M0 24V0h24v24H0zM6.951 5.896l4.112 7.708v5.064h1.583v-4.972l4.148-7.799h-1.749l-2.457 4.875c-.372.745-.688 1.434-.688 1.434s-.297-.708-.651-1.434L8.831 5.896h-1.88z" />
            </svg>
            <span class="text-sm font-medium text-muted-foreground">
              Approuvé par les startups de YC
            </span>
          </div>
        </div>

        <div class="animate-fade-up max-w-3xl mx-auto relative z-10" style="animation-fill-mode: both;">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-tight">
            <span class="text-foreground">Agence Reddit : </span>
            <span class="text-gradient">Générez des leads qualifiés</span>
            <span class="text-foreground"> pour votre Startup</span>
          </h1>
        </div>

        <div class="animate-fade-up mt-6 max-w-2xl mx-auto relative z-10" style="animation-delay: 200ms; animation-fill-mode: both;">
          <p class="text-lg md:text-xl text-muted-foreground leading-relaxed">
            UpvotePartners est <strong class="text-foreground">l'agence Reddit</strong> n°1 en France, spécialisée dans l'acquisition organique pour les startups. Nous créons du contenu stratégique qui se positionne sur Google, génère des leads qualifiés et fait citer votre marque par les moteurs d'IA.
          </p>
        </div>

        <div class="animate-fade-up mt-8 relative z-10" style="animation-delay: 500ms; animation-fill-mode: both;">
          <CTAButton client:visible label="Réserver un audit Reddit gratuit" className="animate-wiggle-glow" />
          <p class="mt-4 text-sm text-muted-foreground font-medium animate-pulse">
            🔥 Places très limitées, nous n'acceptons que quelques clients à la fois
          </p>
        </div>

        <LogoBanner title="Rejoignez les Startups qui utilisent Reddit comme canal d'acquisition" />
      </section>

      <!-- ============================================================
           WHY REDDIT IN 2026
           ============================================================ -->
      <section class="py-24 px-6 bg-gradient-section relative overflow-hidden">
        <div class="max-w-5xl mx-auto relative z-10">
          <div class="animate-fade-up" style="animation-fill-mode: both;">
            <div class="text-center mb-4">
              <span class="inline-block px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium mb-4">
                Pourquoi Reddit ?
              </span>
            </div>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground text-center mb-8 leading-tight max-w-3xl mx-auto">
              Reddit est devenu <span class="text-gradient">incontournable</span> en 2026
            </h2>
          </div>

          <div class="animate-fade-up" style="animation-delay: 100ms; animation-fill-mode: both;">
            <div class="max-w-3xl mx-auto mb-16 space-y-6">
              <p class="text-lg text-muted-foreground text-center leading-relaxed">
                En 2024, Google a signé un partenariat à 60M$/an avec Reddit pour intégrer ses discussions dans les résultats de recherche. Résultat : les threads Reddit dominent désormais les SERPs pour les requêtes de recommandation. Parallèlement, les moteurs IA (ChatGPT, Perplexity, Claude) citent Reddit de manière disproportionnée dans leurs réponses car c'est du contenu authentique, vérifié par la communauté.
              </p>
              <p class="text-lg text-muted-foreground text-center leading-relaxed">
                Pour les startups B2B, c'est une opportunité unique : une <strong class="text-foreground">agence Reddit</strong> comme UpvotePartners peut positionner votre marque là où vos prospects cherchent activement des recommandations : dans les discussions Reddit qui apparaissent sur Google ET dans les réponses des IA génératives.
              </p>
            </div>
          </div>

          <div class="grid md:grid-cols-3 gap-6">
            <!-- Stat 1: 23M -->
            <div class="animate-slide-up" style="animation-delay: 200ms; animation-fill-mode: both;">
              <div class="p-6 rounded-2xl bg-card/80 border border-border/50 hover:border-primary/30 transition-all duration-300 text-center h-full">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-primary"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div class="text-3xl font-bold text-primary mb-2">23M</div>
                <div class="text-sm font-semibold text-foreground mb-1">utilisateurs actifs/jour</div>
                <p class="text-sm text-muted-foreground">Reddit est le 6ème site le plus visité en France (Similarweb, 2026)</p>
              </div>
            </div>

            <!-- Stat 2: Top 3 -->
            <div class="animate-slide-up" style="animation-delay: 300ms; animation-fill-mode: both;">
              <div class="p-6 rounded-2xl bg-card/80 border border-border/50 hover:border-primary/30 transition-all duration-300 text-center h-full">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-primary"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                </div>
                <div class="text-3xl font-bold text-primary mb-2">Top 3</div>
                <div class="text-sm font-semibold text-foreground mb-1">dans les SERPs Google</div>
                <p class="text-sm text-muted-foreground">Les threads Reddit se positionnent dans le top 3 pour les requêtes de recommandation</p>
              </div>
            </div>

            <!-- Stat 3: +300% -->
            <div class="animate-slide-up" style="animation-delay: 400ms; animation-fill-mode: both;">
              <div class="p-6 rounded-2xl bg-card/80 border border-border/50 hover:border-primary/30 transition-all duration-300 text-center h-full">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-primary"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                </div>
                <div class="text-3xl font-bold text-primary mb-2">+300%</div>
                <div class="text-sm font-semibold text-foreground mb-1">trafic organique Reddit</div>
                <p class="text-sm text-muted-foreground">Croissance du trafic SEO des pages Reddit depuis le partenariat Google-Reddit 2024</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================================================
           PROBLEM SECTION
           ============================================================ -->
      <section class="py-24 px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto relative z-10">
          <div class="animate-fade-up" style="animation-fill-mode: both;">
            <div class="text-center mb-4">
              <span class="inline-block px-3 py-1 rounded-full bg-destructive/10 text-destructive text-sm font-medium mb-4">
                Le problème
              </span>
            </div>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground text-center mb-8 leading-tight max-w-3xl mx-auto">
              La plupart des startups échouent sur Reddit. <span class="text-gradient">Pas nos clients.</span>
            </h2>
          </div>

          <div class="animate-fade-up" style="animation-delay: 100ms; animation-fill-mode: both;">
            <p class="text-lg md:text-xl text-muted-foreground text-center mb-16 max-w-2xl mx-auto leading-relaxed">
              Reddit est un canal ultra-puissant, mais ses communautés détestent le marketing. Sans la bonne approche, vos posts sont supprimés, vos comptes bannis, et vous perdez des mois. Notre agence Reddit a développé une méthode qui contourne ces obstacles.
            </p>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            <!-- Without card -->
            <div class="animate-fade-up" style="animation-delay: 150ms; animation-fill-mode: both;">
              <div class="group h-full">
                <div class="h-full bg-card shadow-card rounded-2xl p-8 border border-destructive/20 transition-all duration-500 hover:shadow-lg hover:border-destructive/40">
                  <div class="flex items-center gap-4 mb-8">
                    <div class="w-12 h-12 rounded-xl bg-destructive/10 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-destructive"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                    </div>
                    <div>
                      <h3 class="text-xl font-bold text-foreground">Reddit en interne</h3>
                      <p class="text-sm text-muted-foreground">Ce qui arrive sans expertise Reddit</p>
                    </div>
                  </div>
                  <ul class="space-y-5">
                    <li class="flex items-start gap-4">
                      <div class="w-6 h-6 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-destructive"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      </div>
                      <span class="text-muted-foreground">Posts supprimés par les modérateurs</span>
                    </li>
                    <li class="flex items-start gap-4">
                      <div class="w-6 h-6 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-destructive"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      </div>
                      <span class="text-muted-foreground">Comptes bannis après quelques posts</span>
                    </li>
                    <li class="flex items-start gap-4">
                      <div class="w-6 h-6 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-destructive"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      </div>
                      <span class="text-muted-foreground">Contenus perçus comme du spam</span>
                    </li>
                    <li class="flex items-start gap-4">
                      <div class="w-6 h-6 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-destructive"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      </div>
                      <span class="text-muted-foreground">Aucun résultat après des mois d'efforts</span>
                    </li>
                    <li class="flex items-start gap-4">
                      <div class="w-6 h-6 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-destructive"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      </div>
                      <span class="text-muted-foreground">Perte de temps sur les mauvais subreddits</span>
                    </li>
                    <li class="flex items-start gap-4">
                      <div class="w-6 h-6 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-destructive"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      </div>
                      <span class="text-muted-foreground">Aucune visibilité sur Google ou les IA</span>
                    </li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- With UpvotePartners card -->
            <div class="animate-fade-up" style="animation-delay: 250ms; animation-fill-mode: both;">
              <div class="group h-full">
                <div class="relative h-full">
                  <div class="absolute -inset-0.5 bg-gradient-to-r from-primary/30 to-primary/10 rounded-2xl blur opacity-0 group-hover:opacity-100 transition duration-500"></div>
                  <div class="relative h-full bg-card shadow-card rounded-2xl p-8 border-2 border-primary/50 transition-all duration-500 hover:shadow-card-hover overflow-hidden">
                    <div class="absolute top-0 right-0 overflow-hidden">
                      <div class="bg-primary text-primary-foreground text-xs font-bold px-4 py-1.5">
                        ✨ Avec notre agence Reddit
                      </div>
                    </div>
                    <div class="flex items-center gap-4 mb-8">
                      <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center animate-glow-pulse">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-primary"><path d="M20 6 9 17l-5-5"/></svg>
                      </div>
                      <div>
                        <h3 class="text-xl font-bold text-foreground">Avec UpvotePartners</h3>
                        <p class="text-sm text-muted-foreground">Résultats mesurables</p>
                      </div>
                    </div>
                    <ul class="space-y-5">
                      <li class="flex items-start gap-4">
                        <div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-primary"><path d="M20 6 9 17l-5-5"/></svg>
                        </div>
                        <span class="text-foreground font-medium">Contenu approuvé et upvoté par la communauté</span>
                      </li>
                      <li class="flex items-start gap-4">
                        <div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-primary"><path d="M20 6 9 17l-5-5"/></svg>
                        </div>
                        <span class="text-foreground font-medium">Comptes warm-up avec karma authentique</span>
                      </li>
                      <li class="flex items-start gap-4">
                        <div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-primary"><path d="M20 6 9 17l-5-5"/></svg>
                        </div>
                        <span class="text-foreground font-medium">Posts à valeur ajoutée qui mentionnent votre marque naturellement</span>
                      </li>
                      <li class="flex items-start gap-4">
                        <div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-primary"><path d="M20 6 9 17l-5-5"/></svg>
                        </div>
                        <span class="text-foreground font-medium">Leads qualifiés dès les premières semaines</span>
                      </li>
                      <li class="flex items-start gap-4">
                        <div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-primary"><path d="M20 6 9 17l-5-5"/></svg>
                        </div>
                        <span class="text-foreground font-medium">Ciblage précis des communautés où se trouve votre ICP</span>
                      </li>
                      <li class="flex items-start gap-4">
                        <div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-primary"><path d="M20 6 9 17l-5-5"/></svg>
                        </div>
                        <span class="text-foreground font-medium">Threads positionnés dans Google + cités par les IA</span>
                      </li>
                    </ul>
                    <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-primary to-transparent opacity-50"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================================================
           METHODOLOGY
           ============================================================ -->
      <section id="how-it-works" class="py-24 px-6 bg-gradient-section relative overflow-hidden">
        <div class="max-w-3xl mx-auto relative z-10">
          <div class="animate-fade-up text-center mb-16" style="animation-fill-mode: both;">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 text-primary text-sm font-medium mb-6 border border-primary/20">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
              Notre méthode en 5 étapes
            </span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-8 max-w-3xl mx-auto">
              Comment notre <span class="text-primary">agence Reddit</span> génère vos leads
            </h2>
            <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
              Une méthodologie éprouvée sur 30+ campagnes Reddit B2B. Chaque étape est conçue pour maximiser l'impact tout en respectant les guidelines de Reddit.
            </p>
          </div>

          <div class="flex flex-col gap-3">
            <!-- Step 1 -->
            <div class="animate-slide-up" style="animation-delay: 0ms; animation-fill-mode: both;">
              <div class="flex items-start gap-6 p-6 rounded-2xl bg-card border border-border/50 hover:border-primary/30 transition-all duration-300">
                <div class="flex-shrink-0 w-14 h-14 rounded-2xl bg-gradient-to-br from-primary to-primary/80 flex items-center justify-center shadow-lg shadow-primary/20">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-primary-foreground"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                </div>
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-xs font-bold text-primary bg-primary/10 px-2 py-0.5 rounded-full">Étape 1</span>
                    <h3 class="text-lg font-bold text-foreground">Audit & stratégie de subreddits</h3>
                  </div>
                  <p class="text-muted-foreground leading-relaxed">On identifie les subreddits où votre ICP (Ideal Customer Profile) est actif. On analyse le ton, les règles, les types de posts qui performent, et la présence de vos concurrents. On sélectionne 5 à 15 communautés stratégiques par campagne.</p>
                </div>
              </div>
            </div>

            <!-- Step 2 -->
            <div class="animate-slide-up" style="animation-delay: 100ms; animation-fill-mode: both;">
              <div class="flex items-start gap-6 p-6 rounded-2xl bg-card border border-border/50 hover:border-primary/30 transition-all duration-300">
                <div class="flex-shrink-0 w-14 h-14 rounded-2xl bg-gradient-to-br from-primary to-primary/80 flex items-center justify-center shadow-lg shadow-primary/20">
