---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  robots?: string;
  lang?: 'fr' | 'en';
  alternateUrl?: string;
}

const { title, description, canonical = 'https://upvotepartners.com', ogImage = 'https://upvotepartners.com/logo.webp', robots = 'index, follow', lang = 'fr', alternateUrl } = Astro.props;

const ogLocale = lang === 'en' ? 'en_US' : 'fr_FR';
const metaLanguage = lang === 'en' ? 'en' : 'fr';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="author" content="UpvotePartners">
    <meta name="robots" content={robots}>
    <meta name="language" content={metaLanguage}>
    {lang === 'fr' && <>
      <meta name="geo.region" content="FR">
      <meta name="geo.placename" content="France">
    </>}
    <link rel="canonical" href={canonical}>

    {/* Hreflang tags */}
    {alternateUrl && (
      <>
        <link rel="alternate" hreflang={lang} href={canonical} />
        <link rel="alternate" hreflang={lang === 'fr' ? 'en' : 'fr'} href={alternateUrl} />
        <link rel="alternate" hreflang="x-default" href={lang === 'en' ? canonical : alternateUrl} />
      </>
    )}


    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonical}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={ogImage}>
    <meta property="og:image:width" content="512">
    <meta property="og:image:height" content="512">
    <meta property="og:image:alt" content="UpvotePartners | Agence Marketing Reddit & GEO">
    <meta property="og:locale" content={ogLocale}>
    <meta property="og:site_name" content="UpvotePartners">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@mateodr_">
    <meta name="twitter:creator" content="@mateodr_">
    <meta name="twitter:url" content={canonical}>
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={ogImage}>

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/webp" href="/logo.webp">
    <link rel="apple-touch-icon" href="/logo.webp">

    <!-- Preconnect for third-party scripts -->
    <link rel="preconnect" href="https://t.contentsquare.net">
    <link rel="dns-prefetch" href="https://t.contentsquare.net">

    <!-- Contentsquare / Hotjar — loaded after main thread is idle -->
    <script>
      window.addEventListener('load', function() {
        requestIdleCallback(function() {
          var s = document.createElement('script');
          s.src = 'https://t.contentsquare.net/uxa/fe3725e302c65.js';
          document.head.appendChild(s);
        });
      });
    </script>

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "UpvotePartners",
      "description": "Agence spécialisée en acquisition de clients via Reddit et en Generative Engine Optimization (GEO) pour les startups. Stratégie organique, leads qualifiés, visibilité SEO et citations IA.",
      "url": "https://upvotepartners.com",
      "logo": "https://upvotepartners.com/logo.webp",
      "image": "https://upvotepartners.com/logo.webp",
      "founder": {
        "@type": "Person",
        "name": "Matéo Drouillard",
        "sameAs": [
          "https://x.com/mateodr_",
          "https://www.linkedin.com/in/mateodrouillard/"
        ]
      },
      "serviceType": ["Agence Marketing Reddit", "Agence GEO", "Generative Engine Optimization"],
      "areaServed": [
        { "@type": "Country", "name": "France" },
        { "@type": "Country", "name": "Belgium" },
        { "@type": "Country", "name": "Switzerland" },
        { "@type": "Country", "name": "Canada" }
      ],
      "availableLanguage": ["French", "English"],
      "priceRange": "€€€",
      "sameAs": [
        "https://x.com/mateodr_",
        "https://www.linkedin.com/in/mateodrouillard/"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Services Marketing Reddit & GEO",
        "itemListElement": [
          {
            "@type": "Offer",
            "name": "Reddit Growth Foundation",
            "description": "4 à 5 posts par mois, 25 commentaires ciblés, gestion multi-comptes, reporting mensuel",
            "price": "3000",
            "priceCurrency": "EUR"
          },
          {
            "@type": "Offer",
            "name": "Reddit Growth Engine",
            "description": "6 à 7 posts par mois, 50 commentaires ciblés, gestion multi-comptes, reporting mensuel",
            "price": "5000",
            "priceCurrency": "EUR"
          },
          {
            "@type": "Offer",
            "name": "Reddit Market Dominance",
            "description": "7 à 8 posts par mois, 100 commentaires ciblés, domination de niche, reporting mensuel",
            "price": "10000",
            "priceCurrency": "EUR"
          }
        ]
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "bestRating": "5",
        "worstRating": "1",
        "reviewCount": "12"
      }
    }
    </script>

    <slot name="head" />
  </head>

  <body>
    <slot />
  </body>
</html>
